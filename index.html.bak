</head><body><header><div class="container"><div class="header-top"><div><div style="display:inline-flex;align-items:center;gap:10px;"><div style="width:44px;height:44px;border-radius:50%;background:#CA8A04;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',sans-serif;font-weight:800;color:#fafafa;letter-spacing:-0.02em;line-height:1;color:#FEFCE8;font-size:19px;">AJ</div><span style="font-family:'Playfair Display',sans-serif;font-weight:800;color:#fafafa;letter-spacing:-0.02em;line-height:1;font-size:22px;">Ajaccio</span></div><div style="color:rgba(255,255,255,0.65);font-size:.8rem;margin-top:.4rem">Ajaccio, France</div></div><div class="header-contact"><a href="mailto:contact@geotechnique.vip">contact@geotechnique.vip</a></div></div><nav aria-label="breadcrumb" style="padding:.3rem 0;font-size:.78rem;color:rgba(255,255,255,0.75)"><ol style="list-style:none;display:flex;gap:.35rem;flex-wrap:wrap;padding:0;margin:0"><li><a href="/" style="color:inherit;text-decoration:none">Accueil</a></li><li>›</li><li aria-current="page" style="color:rgba(255,255,255,0.95)">Géotechnique à Ajaccio</li></ol></nav><h1>Géotechnique à Ajaccio</h1></div></header><div class="container"><div class="content-area"><aside class="sidebar"><nav><a href="index.html" class="home">Accueil</a><div class="cat-item" data-cat="investigation"><div class="cat-row"><a href="/investigation/" class="cat-name">Exploration</a><button class="cat-toggle" aria-expanded="false" aria-label="Expandir Exploration"><span class="cat-arrow">▼</span></button></div><div class="cat-sub" hidden><a href="/essai-cpt/">Essai CPT (Cone Penetration Test)</a><a href="/sondages-spt/">Essai SPT (Standard Penetration Test)</a><a href="/puits-inspection/">Fouille d'essai (Puits d'exploration)</a></div></div><div class="cat-item" data-cat="labo-in-situ"><div class="cat-row"><a href="/labo-in-situ/" class="cat-name">Essais in situ</a><button class="cat-toggle" aria-expanded="false" aria-label="Expandir Essais in situ"><span class="cat-arrow">▼</span></button></div><div class="cat-sub" hidden><a href="/densite-cone-sable/">Essai de densité sur site (méthode du cône de sable)</a><a href="/permeabilite-in-situ/">Essai de perméabilité sur site (Lefranc/Lugeon)</a></div></div><div class="cat-item" data-cat="laboratoire"><div class="cat-row"><a href="/laboratoire/" class="cat-name">Laboratoire</a><button class="cat-toggle" aria-expanded="false" aria-label="Expandir Laboratoire"><span class="cat-arrow">▼</span></button></div><div class="cat-sub" hidden><a href="/granulometrie/">Analyse granulométrique (tamisage + hydromètre)</a><a href="/essais-proctor/">Essai Proctor (Normal ou Modifié)</a><a href="/triaxial/">Essai triaxial</a></div></div><div class="cat-item" data-cat="fondations"><div class="cat-row"><a href="/fondations/" class="cat-name">Fondations</a><button class="cat-toggle" aria-expanded="false" aria-label="Expandir Fondations"><span class="cat-arrow">▼</span></button></div><div class="cat-sub" hidden><a href="/semelles/">Conception de fondations superficielles</a><a href="/pieux/">Conception de fondations sur pieux</a><a href="/radiers/">Conception de radier général</a></div></div><div class="cat-item" data-cat="talus"><div class="cat-row"><a href="/talus/" class="cat-name">Pentes et murs</a><button class="cat-toggle" aria-expanded="false" aria-label="Expandir Pentes et murs"><span class="cat-arrow">▼</span></button></div><div class="cat-sub" hidden><a href="/stabilite-talus/">Analyse de stabilité des pentes</a><a href="/ancrages/">Conception d'ancrages actifs/passifs</a><a href="/murs-soutenement/">Conception de murs de soutènement</a></div></div><div class="cat-item" data-cat="amelioration-sols"><div class="cat-row"><a href="/amelioration-sols/" class="cat-name">Amélioration</a><button class="cat-toggle" aria-expanded="false" aria-label="Expandir Amélioration"><span class="cat-arrow">▼</span></button></div><div class="cat-sub" hidden><a href="/injections/">Conception d'injections (grouting)</a><a href="/colonnes-ballastees/">Conception de colonnes ballastées (stone columns)</a><a href="/vibrocompactage/">Conception de vibrocompactage</a></div></div><div class="cat-item" data-cat="sismique"><div class="cat-row"><a href="/sismique/" class="cat-name">Sismique</a><button class="cat-toggle" aria-expanded="false" aria-label="Expandir Sismique"><span class="cat-arrow">▼</span></button></div><div class="cat-sub" hidden><a href="/liquefaction/">Analyse de liquéfaction des sols</a><a href="/isolation-sismique/">Conception d'isolation sismique à la base</a><a href="/microzonage-sismique/">Microzonage sismique</a></div></div><div class="cat-item" data-cat="geotechnique-routiere"><div class="cat-row"><a href="/geotechnique-routiere/" class="cat-name">Géotechnique routière</a><button class="cat-toggle" aria-expanded="false" aria-label="Expandir Géotechnique routière"><span class="cat-arrow">▼</span></button></div><div class="cat-sub" hidden><a href="/chaussee-rigide/">Conception de chaussées rigides</a><a href="/chaussee-souple/">Conception de chaussées souples</a><a href="/cbr-routier/">Étude CBR pour conception routière</a></div></div><div class="cat-item" data-cat="geophysique"><div class="cat-row"><a href="/geophysique/" class="cat-name">Géophysique</a><button class="cat-toggle" aria-expanded="false" aria-label="Expandir Géophysique"><span class="cat-arrow">▼</span></button></div><div class="cat-sub" hidden><a href="/masw/">MASW / VS30 (vitesse des ondes de cisaillement)</a><a href="/resistivite/">Résistivité électrique / SEV (Sondage Électrique Vertical)</a><a href="/refraction-sismique/">Tomographie sismique (réfraction/réflexion)</a></div></div><div class="cat-item" data-cat="excavations"><div class="cat-row"><a href="/excavations/" class="cat-name">Excavations souterraines</a><button class="cat-toggle" aria-expanded="false" aria-label="Expandir Excavations souterraines"><span class="cat-arrow">▼</span></button></div><div class="cat-sub" hidden><a href="/tunnels-sol-mou/">Analyse géotechnique pour tunnels en sols mous</a><a href="/excavations-profondes/">Conception géotechnique des excavations profondes</a><a href="/surveillance-excavations/">Surveillance géotechnique des excavations</a></div></div></nav></aside><main><section><p>À Ajaccio, on ne creuse pas longtemps sans tomber sur le granit. En surface, ce sont souvent des arènes granitiques, ces sables grossiers issus de l'altération qui compliquent le dimensionnement des fondations. Trop d'entreprises démarrent les terrassements avec un simple sondage visuel. Mauvaise idée. Une étude de mécanique des sols ici doit impérativement caractériser l'épaisseur de l'horizon altéré et la fracturation du substratum. On a vu des semelles filantes tasser de 4 cm sur un horizon d'arène hétérogène mal reconnu. Pour éviter ça, nous croisons systématiquement les <a data-interlink="1" href="/essai-cpt/">essais CPT</a> avec des sondages carottés, surtout quand le rocher est sub-affleurant dans le secteur des Sanguinaires.</p></section><blockquote style="border-left:4px solid #CA8A04;background:rgba(0,0,0,.03);padding:1rem 1.25rem;margin:1.5rem 0 1.5rem 1rem;font-style:italic;color:#333;font-size:1.05rem;line-height:1.55;border-radius:0 6px 6px 0">En Corse cristalline, l'épaisseur de l'arène granitique commande le mode de fondation, pas le rocher sain.</blockquote><figure style="margin:2rem auto;text-align:center;max-width:60%"><img src="/img/estudio-mecanica-suelos-1.webp" alt="Géotechnique à Ajaccio" width="600" height="300" loading="eager" decoding="async" style="width:100%;max-height:160px;object-fit:cover;border-radius:8px" fetchpriority="high"><figcaption style="font-size:.78rem;color:#64748b;margin-top:.4rem">Géotechnique à Ajaccio</figcaption></figure><section><h2>Portée du travail à Ajaccio</h2><div>Le sous-sol ajaccien est marqué par une géologie de granite hercynien intensément diaclasé. La nappe phréatique, perchée dans les arènes, fluctue fortement en saison. Nous voyons souvent des teneurs en eau passer de 8% en été à 22% en hiver sur le même horizon, ce qui modifie radicalement la portance. L'étude de mécanique des sols intègre donc des essais de <a href="/triaxial/">cisaillement triaxial</a> pour mesurer la cohésion effective en conditions saturées, et des <a href="/essais-proctor/">essais Proctor</a> pour caler le compactage des remblais sur les terrasses alluviales du Prunelli. La norme NF P94-500 régit les missions géotechniques, et nous appliquons strictement la phase G2 AVP pour sécuriser les descendes de charge en zone de versant. <ul><li>Reconnaissance au pénétromètre dynamique lourd</li><li>Sondages carottés avec récupération du rocher altéré</li><li>Essais de laboratoire sur arènes (CD, CU)</li><li>Cartographie de la fracturation (RQD)</li></ul></div></section><div style="max-width:700px;margin:1.5rem auto;border-left:4px solid #CA8A04;border-radius:6px;overflow:hidden;background:#FFF;box-shadow:0 1px 3px rgba(0,0,0,.05)"><table style="width:100%;border-collapse:collapse;font-size:.92rem"><thead><tr style="background:#CA8A04;color:#FFF"><th style="padding:.75rem 1rem;text-align:left;font-weight:600">Paramètre</th><th style="padding:.75rem 1rem;text-align:left;font-weight:600">Valeur typique</th></tr></thead><tbody><tr style="background:#FAFAF7"><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE">Profondeur du substratum sain</td><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE;color:#222;font-weight:500">1,5 à 15 m (variable)</td></tr><tr style="background:#FFFFFF"><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE">RQD (Rock Quality Designation)</td><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE;color:#222;font-weight:500">< 50% zones diaclasées</td></tr><tr style="background:#FAFAF7"><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE">Portance admissible arènes</td><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE;color:#222;font-weight:500">0,4 à 1,2 MPa</td></tr><tr style="background:#FFFFFF"><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE">Angle de frottement granit altéré</td><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE;color:#222;font-weight:500">32° à 38°</td></tr><tr style="background:#FAFAF7"><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE">Teneur en eau arènes hiver</td><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE;color:#222;font-weight:500">18% à 25%</td></tr><tr style="background:#FFFFFF"><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE">Classe sismique (Eurocode 8)</td><td style="padding:.7rem 1rem;border-bottom:1px solid #EEE;color:#222;font-weight:500">Zone 2 (agR=1,6 m/s²)</td></tr></tbody></table></div><section><h2>Défis techniques typiques à Ajaccio</h2><p>Un chantier de 30 logements rue du Cardinal Fesch nous a marqués. Le maître d'ouvrage avait ignoré l'étude de mécanique des sols en phase conception. Résultat : le talus amont a glissé de 60 cm après une pluie centennale de novembre. L'arène granitique, non confinée, s'était liquéfiée localement. Le coût de la reprise en <a data-interlink="1" href="/ancrages/">paroi clouée</a> a dépassé de loin le budget initial de reconnaissance. À Ajaccio, la combinaison pente raide et arènes épaisses est le scénario le plus risqué. Les circulations d'eau le long des diaclases verticales créent des sous-pressions derrière les murs de soutènement qu'un simple calcul à sec ne détecte pas. Une mission G2 PRO bien menée anticipe ces désordres.</p></section><section class="block mid-cta-726e" style="padding:2rem 0"><div style="max-width:720px;margin:0 auto;background:linear-gradient(135deg,#16A34A15,#16A34A08);border-left:4px solid #16A34A;padding:1.6rem 1.8rem;border-radius:8px;text-align:center"><h3 style="margin:0 0 .4rem;font-size:1.15rem;color:#1E293B;text-align:center">Besoin d'une évaluation géotechnique ?</h3><p style="margin:0 0 1rem;color:#64748B;font-size:.92rem;text-align:center">Réponse sous 24h.</p><div style="margin:.4rem 0 0;text-align:center"><a href="mailto:contact@geotechnique.vip" style="display:inline-block;background:#16A34A;color:#FFF !important;padding:1rem 2rem;border-radius:8px;text-decoration:none;font-weight:800;font-size:1.05rem;box-shadow:0 4px 12px rgba(0,0,0,.15)">E-mail: contact@geotechnique.vip</a></div></div></section><div class="normas"><strong>Normes applicables:</strong> NF P94-500 (missions géotechniques, révision 2013), NF EN 1997-1 (Eurocode 7 - calcul géotechnique), NF EN 1998-5 (Eurocode 8 - fondations et sismicité), NF P94-261 (fondations superficielles, justification) </div><section><h2>Nos services</h2><p>Notre approche de l'étude de mécanique des sols à Ajaccio se décline en deux axes principaux, adaptés à la morphologie granitique locale.</p><style>/*afx*/.servicios-grid a.servicio-link:hover{border-color:#CA8A04;box-shadow:0 4px 14px rgba(0,0,0,.08);transform:translateY(-2px)}
.servicios-grid a.servicio-link{display:block;text-decoration:none;color:inherit;cursor:pointer}
.servicios-grid{display:flex;flex-wrap:wrap;gap:1rem;justify-content:flex-start}
.servicios-grid a.servicio-link:hover .servicio-arrow{transform:translateX(4px);opacity:1}
.servicio-arrow{position:absolute;right:1rem;bottom:.8rem;color:#CA8A04;font-weight:700;opacity:.55;transition:transform .18s,opacity .18s}
.servicios-grid .servicio{flex:0 0 calc(50% - .5rem);min-width:260px;padding:1rem 1.2rem;border:1px solid #E5E7EB;border-radius:10px;background:#FFFFFF;position:relative;transition:border-color .18s,box-shadow .18s,transform .18s}
.servicios-grid a.servicio-link:hover h3{color:#CA8A04}/*sbhfix*/aside .sb-home{color:#FFF !important}</style><div class="servicios-grid"><div class="servicio"><h3>Étude géotechnique d'avant-projet (G2 AVP)</h3><p>Pour les programmes immobiliers de la périphérie ajaccienne. Nous définissons le modèle géotechnique par sondages destructifs et carottés, avec essais pressiométriques dans les arènes. Ce livrable permet de choisir entre semelles superficielles et fondations semi-profondes en fonction de la profondeur du rocher altéré.</p></div><div class="servicio"><h3>Étude de stabilité de versant (G2 PRO)</h3><p>Pour les villas sur les hauteurs de la route des Îles. Nous modélisons les cercles de glissement (Bishop, Spencer) en tenant compte de la fracturation du granite et des venues d'eau. L'étude de mécanique des sols inclut alors le dimensionnement de murs poids ou de gabions ancrés.</p></div></div></section><section><h2>Questions fréquentes</h2><details><summary>Quel est le prix d'une étude de mécanique des sols à Ajaccio ?</summary><p>Pour une mission type G2 AVP sur une parcelle individuelle, le budget se situe entre 2.980 € et 4.890 € hors taxes. Ce montant couvre l'intervention de la foreuse, les essais in situ (pénétromètre, pressiomètre), le rapport du laboratoire accrédité COFRAC et l'analyse géotechnique par l'ingénieur. Les projets complexes avec stabilité de talus dépassent cette fourchette.</p></details><details><summary>Faut-il une étude spécifique à cause du granite en Corse ?</summary><p>Oui, absolument. Le granite d'Ajaccio n'est pas une roche homogène. L'altération en boule crée des chaos rocheux avec des passages d'arènes meubles entre des blocs durs. Une étude standard qui ne maille pas assez le terrain peut manquer une poche compressible. Nous utilisons un maillage de sondages plus serré qu'en terrain sédimentaire classique, généralement une maille de 10 mètres.</p></details><details><summary>Combien de temps prend une étude géotechnique à Ajaccio ?</summary><p>La phase de forage dure 1 à 2 jours selon l'accessibilité et la profondeur du rocher. Les essais de laboratoire demandent 2 à 3 semaines pour les cisaillements triaxiaux consolidés drainés. Nous livrons le rapport complet sous 4 semaines en moyenne, avec une synthèse exploitable pour le bureau d'études structure.</p></details></section><section><h2>Couverture à Ajaccio</h2><link rel="stylesheet" href="/css/leaflet-f50c.css"/><div id="mapa-ciudad"></div><script src="/js/leaflet-f50c.js"></script><script>
var map = L.map('mapa-ciudad').setView([41.9192,8.7386], 12);
L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}@2x.png',{attribution:'&copy; OSM &copy; CARTO',subdomains:'abcd',maxZoom:19}).addTo(map);
L.marker([41.9192,8.7386],{icon:L.divIcon({html:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 36" width="24" height="36"><path d="M12 0C5.4 0 0 5.4 0 12c0 9 12 24 12 24s12-15 12-24c0-6.6-5.4-12-12-12z" fill="#E11D48" stroke="#FFF" stroke-width="1.5"/><circle cx="12" cy="12" r="4" fill="#FFF"/></svg>',className:'',iconSize:[24,36],iconAnchor:[12,36]})}).addTo(map);L.circle([41.9192,8.7386],{radius:3000,color:'#CA8A04',fillColor:'#A16207',fillOpacity:0.18,weight:2}).addTo(map).bindPopup('Coverage area — Ajaccio');
</script></section></main></div></div><footer style="background:linear-gradient(135deg,#14532D,#A1620722);color:#FFF;padding:3rem 1.5rem"><div style="max-width:720px;margin:0 auto;text-align:center"><h3 style="font-size:1.4rem;margin:0 0 .5rem;color:#FFF">Prêt pour votre projet ?</h3><p style="margin:0 0 1.5rem;color:rgba(255,255,255,.8)">Ajaccio, France</p><a href="mailto:contact@geotechnique.vip" style="display:inline-block;background:#A16207;color:#FFF !important;padding:.9rem 2.2rem;border-radius:8px;text-decoration:none;font-weight:700;font-size:1rem;box-shadow:0 4px 14px rgba(0,0,0,.25)">Demander un devis — contact@geotechnique.vip</a><p style="margin:1.8rem 0 0;font-size:.82rem;color:rgba(255,255,255,.5)">© 2026 Géotechnique · Tous droits réservés</p></div><div data-authority-refs class="authority-refs" style="text-align:center;font-size:.8rem;padding:.5rem 0;opacity:.6"><strong>Références:</strong>Normes AFNOR · Eurocode 7 · ISO Géotechnique</div><div class="updated-info" data-updated="2026-04-11" style="text-align:center;font-size:.85rem;opacity:.7;padding:.5rem 0">Dernière mise à jour: 2026-04-11</div></footer><script>
// Sidebar cat-toggle: click expande/contrae cat-sub (REGLA 30b)
document.addEventListener('click', function(e) {
var btn = e.target.closest('.cat-toggle');
if (!btn) return;
e.preventDefault();
var item = btn.closest('.cat-item');
if (!item) return;
var sub = item.querySelector('.cat-sub');
if (!sub) return;
var open = btn.getAttribute('aria-expanded') === 'true';
btn.setAttribute('aria-expanded', open ? 'false' : 'true');
if (open) {
sub.setAttribute('hidden', '');
} else {
sub.removeAttribute('hidden');
}
});
</script></body></html>